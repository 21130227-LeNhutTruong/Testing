{
    "configuration": {
        "device": {
            "orientation": "landscape",
            "deviceName": "Desktop"
        }
    },
    "type": "clickpath",
    "version": "1.0",
    "events": [
        {
            "description": "Loading of \"https://cellphones.com.vn/\"",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {},
            "type": "navigate",
            "url": "https://cellphones.com.vn/"
        },
        {
            "description": "click",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "dom",
                        "value": "document.evaluate('//div[@id=\\'topInfoBar\\']/div[2]/a/span', document, null, XPathResult.ANY_TYPE, null).iterateNext()"
                    }
                ]
            },
            "type": "click",
            "button": 0
        },
        {
            "description": "pause",
            "target": {},
            "type": "javascript",
            "javaScript": "api.startAsyncSyntheticEvent(); \n                setTimeout(() => {api.finish()}, 3000);"
        },
        {
            "description": "click",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "dom",
                        "value": "document.evaluate('//div[@id=\\'boxOptions\\']/div/div/input', document, null, XPathResult.ANY_TYPE, null).iterateNext()"
                    }
                ]
            },
            "type": "click",
            "button": 0
        },
        {
            "description": "click",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "css",
                        "value": "#boxSearchProvince"
                    }
                ]
            },
            "type": "click",
            "button": 0
        },
        {
            "description": "select option",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {},
            "type": "javascript",
            "javaScript": "\n                    let add = false;\n                    let x = typeof $ !== 'undefined' ? $('#boxSearchProvince')[0] : document.querySelector('#boxSearchProvince');\n                    for (i = 0; i < x.options.length; i++) {\n                        if (x.options[i].text === \"Bình Định\") {\n                            if(add) {\n                                x.options[i].selected = true;\n                            } else {\n                                x.options.selectedIndex = i;\n                            }\n                        }\n                    }"
        }
    ]
}