{
    "configuration": {
        "device": {
            "orientation": "landscape",
            "deviceName": "Desktop"
        }
    },
    "type": "clickpath",
    "version": "1.0",
    "events": [
        {
            "description": "Loading of \"https://cellphones.com.vn/\"",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {},
            "type": "navigate",
            "url": "https://cellphones.com.vn/"
        },
        {
            "description": "click",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "dom",
                        "value": "document.evaluate('//div[@id=\\'topInfoBar\\']/div[2]/a/span', document, null, XPathResult.ANY_TYPE, null).iterateNext()"
                    }
                ]
            },
            "type": "click",
            "button": 0
        },
        {
            "description": "pause",
            "target": {},
            "type": "javascript",
            "javaScript": "api.startAsyncSyntheticEvent(); \n                setTimeout(() => {api.finish()}, 3000);"
        },
        {
            "description": "click",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "dom",
                        "value": "document.evaluate('//div[@id=\\'boxOptions\\']/div/div/input', document, null, XPathResult.ANY_TYPE, null).iterateNext()"
                    }
                ]
            },
            "type": "click",
            "button": 0
        },
        {
            "description": "type thủ đức",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "dom",
                        "value": "document.evaluate('//div[@id=\\'boxOptions\\']/div/div/input', document, null, XPathResult.ANY_TYPE, null).iterateNext()"
                    }
                ]
            },
            "type": "keystrokes",
            "textValue": "thủ đức",
            "simulateBlurEvent": true,
            "masked": false
        },
        {
            "description": "click",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "dom",
                        "value": "document.evaluate('//div[@id=\\'boxOptions\\']/div/div/div/ul/li', document, null, XPathResult.ANY_TYPE, null).iterateNext()"
                    }
                ]
            },
            "type": "click",
            "button": 0
        },
        {
            "description": "click",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "dom",
                        "value": "document.evaluate('//div[@id=\\'boxMap\\']/div/div[3]/p', document, null, XPathResult.ANY_TYPE, null).iterateNext()"
                    }
                ]
            },
            "type": "click",
            "button": 0
        },
        {
            "description": "click",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "dom",
                        "value": "document.evaluate('//div[@id=\\'boxMap\\']/div[2]/div/div/canvas', document, null, XPathResult.ANY_TYPE, null).iterateNext()"
                    }
                ]
            },
            "type": "click",
            "button": 0
        }
    ]
}