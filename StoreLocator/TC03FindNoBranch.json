{
    "configuration": {
        "device": {
            "orientation": "landscape",
            "deviceName": "Desktop"
        }
    },
    "type": "clickpath",
    "version": "1.0",
    "events": [
        {
            "description": "Loading of \"https://cellphones.com.vn/\"",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {},
            "type": "navigate",
            "url": "https://cellphones.com.vn/"
        },
        {
            "description": "click",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "dom",
                        "value": "document.evaluate('//div[@id=\\'topInfoBar\\']/div[2]/a/span', document, null, XPathResult.ANY_TYPE, null).iterateNext()"
                    }
                ]
            },
            "type": "click",
            "button": 0
        },
        {
            "description": "pause",
            "target": {},
            "type": "javascript",
            "javaScript": "api.startAsyncSyntheticEvent(); \n                setTimeout(() => {api.finish()}, 3000);"
        },
        {
            "description": "click",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "dom",
                        "value": "document.evaluate('//div[@id=\\'boxOptions\\']/div/div/input', document, null, XPathResult.ANY_TYPE, null).iterateNext()"
                    }
                ]
            },
            "type": "click",
            "button": 0
        },
        {
            "description": "type kon tom",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {
                "locators": [
                    {
                        "type": "dom",
                        "value": "document.evaluate('//div[@id=\\'boxOptions\\']/div/div/input', document, null, XPathResult.ANY_TYPE, null).iterateNext()"
                    }
                ]
            },
            "type": "keystrokes",
            "textValue": "kon tom",
            "simulateBlurEvent": true,
            "masked": false
        },
        {
            "description": "send keys",
            "wait": {
                "waitFor": "page_complete"
            },
            "target": {},
            "type": "javascript",
            "javaScript": "\n                const keys = [13];\n                const elem = document.evaluate('//div[@id=\\'boxOptions\\']/div/div/input', document, null, XPathResult.ANY_TYPE, null).iterateNext();\n                keys.forEach((key) => {\n                    let eventObj = document.createEvent(\"Events\");\n                    eventObj.initEvent(\"keydown\", true, true);\n                    eventObj.key = key;\n                    eventObj.keyCode = key;\n                    eventObj.which = key;\n                    eventObj.charCode = key;\n                    \n                    elem.dispatchEvent(eventObj);\n                    eventObj = document.createEvent(\"Events\");\n                    eventObj.initEvent(\"keypress\", true, true);\n                    eventObj.key = key;\n                    eventObj.keyCode = key;\n                    eventObj.which = key;\n                    eventObj.charCode = key;\n                    elem.dispatchEvent(eventObj);\n                    \n                    eventObj = document.createEvent(\"Events\");\n                    eventObj.initEvent(\"keyup\", true, true);\n                    eventObj.key = key;\n                    eventObj.keyCode = key;\n                    eventObj.which = key;\n                    eventObj.charCode = key;\n                    elem.dispatchEvent(eventObj);\n                });"
        }
    ]
}